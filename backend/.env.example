# Backend — Variables de entorno
# Copiar a backend/.env y rellenar. .env está en .gitignore.

# ----- App -----
APP_ENV=development        # development | staging | production
APP_NAME=cehta-backend
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ----- Database (Supabase Transaction Pooler) -----
# Formato: postgresql+asyncpg://postgres.{PROJECT_REF}:{PASSWORD}@{POOLER_HOST}:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres.dqwwqfhzejscgcynkbip:REEMPLAZAR_PASSWORD@aws-1-us-east-2.pooler.supabase.com:6543/postgres

# Para alembic (requiere driver síncrono psycopg; usa pooler session en 5432 o el mismo en 6543 con statement_cache_size=0)
ALEMBIC_DATABASE_URL=postgresql://postgres.dqwwqfhzejscgcynkbip:REEMPLAZAR_PASSWORD@aws-1-us-east-2.pooler.supabase.com:6543/postgres

# ----- Supabase -----
SUPABASE_URL=https://dqwwqfhzejscgcynkbip.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_JWT_SECRET=REEMPLAZAR_JWT_SECRET

# ----- Security -----
# Si en algún momento emitimos JWTs propios (no ahora). Generar con: openssl rand -hex 32
SECRET_KEY=change-me-dev-only
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- Integraciones (placeholder, rellenar cuando toque) -----
ANTHROPIC_API_KEY=
DROPBOX_REFRESH_TOKEN=
